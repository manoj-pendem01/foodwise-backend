# ============================================================
# FoodWise AI - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=foodwise_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/foodwise_db

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ML Model
MODEL_PATH=app/ml/models/waste_predictor.pkl
MODEL_SCALER_PATH=app/ml/models/scaler.pkl

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATELIMIT_DEFAULT=200 per day;50 per hour

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/foodwise.log
